
// --------------------------------------
// Inventory & Manufacturing (Suppliers, BOM)
// --------------------------------------

model Supplier {
  id              String  @id @default(uuid())
  accountId       String
  name            String
  contactName     String?
  email           String?
  phone           String?
  currency        String  @default("USD")
  leadTimeMin     Int? // Min days
  leadTimeMax     Int? // Max days
  paymentTerms    String? // e.g. "Net 30", "Prepaid"
  leadTimeDefault Int? // Default lead time in days (Avg or Max)

  items    SupplierItem[]
  products WooProduct[]
  internalProducts InternalProduct[]

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([accountId])
}

model SupplierItem {
  id         String  @id @default(uuid())
  supplierId String
  name       String
  sku        String?

  cost     Decimal @db.Decimal(10, 2)
  leadTime Int? // Specific lead time (overrides supplier default)
  moq      Int     @default(1) // Minimum Order Quantity

  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bomItems           BOMItem[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Internal-only products that are not synced to WooCommerce.
/// Used as components in BOMs, tracked in forecasts and reports.
model InternalProduct {
  id          String   @id @default(uuid())
  accountId   String

  name        String
  sku         String?
  description String?  @db.Text

  stockQuantity Int     @default(0)
  cogs          Decimal? @db.Decimal(10, 2)
  miscCosts     Json?    @default("[]")   // Same format as WooProduct
  binLocation   String?

  mainImage   String?
  images      Json?    @default("[]")

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  bomItems    BOMItem[] @relation("InternalProductAsBOMComponent")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, sku])
  @@index([accountId])
}

model BOM {
  id          String @id @default(uuid())
  productId   String
  variationId Int    @default(0) // 0 = Parent/Main Product, >0 = Variant ID

  items BOMItem[]

  product WooProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, variationId])
}

model BOMItem {
  id             String  @id @default(uuid())
  bomId          String
  supplierItemId String?
  childProductId String?
  childVariationId Int?
  internalProductId String?  // Internal product component (not synced to WooCommerce)

  quantity    Decimal @db.Decimal(10, 4) // e.g. 1.5 meters, 0.05 kg
  wasteFactor Decimal @default(0) @db.Decimal(5, 4) // e.g. 0.10 for 10% waste

  /// Soft-deactivation: false when the referenced product/variation no longer exists in WooCommerce.
  /// Deactivated items are skipped during sync and consumption but retained for auditing.
  isActive          Boolean  @default(true)
  deactivatedReason String?  // e.g. "VARIATION_DELETED_IN_WOO", "PRODUCT_404"

  bom              BOM              @relation(fields: [bomId], references: [id], onDelete: Cascade)
  supplierItem     SupplierItem?    @relation(fields: [supplierItemId], references: [id])
  childProduct     WooProduct?      @relation("ProductAsBOMComponent", fields: [childProductId], references: [id])
  childVariation   ProductVariation? @relation(fields: [childProductId, childVariationId], references: [productId, wooId])
  internalProduct  InternalProduct? @relation("InternalProductAsBOMComponent", fields: [internalProductId], references: [id])

  // @@unique([bomId, supplierItemId]) // Removed as it conflicts with optional fields
  @@index([bomId, isActive])
  @@index([childProductId, isActive])
  @@index([internalProductId, isActive])
  @@index([deactivatedReason])
}

/// Tracks individual BOM stock deductions for deterministic crash recovery.
/// Each row represents one component deduction from an order. Recovery logic
/// queries EXECUTED entries without a corresponding order-completion record
/// to decide what needs rollback — no heuristic stock comparison required.
model BOMDeductionLedger {
  id             String   @id @default(uuid())
  accountId      String
  orderId        Int
  componentType  String   // 'WooProduct' | 'ProductVariation' | 'InternalProduct'
  componentId    String
  componentName  String
  wooId          Int?
  parentWooId    Int?     // For variations
  quantityDeducted Float
  previousStock  Float
  newStock       Float
  status         String   @default("EXECUTED") // EXECUTED | ROLLED_BACK
  createdAt      DateTime @default(now())
  rolledBackAt   DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, orderId])
  @@index([status])
}

model PurchaseOrder {
  id         String @id @default(uuid())
  accountId  String
  supplierId String

  orderNumber String? // Optional human readable ID like PO-1001
  status      String  @default("DRAFT") // DRAFT, ORDERED, RECEIVED, CANCELLED

  orderDate    DateTime?
  expectedDate DateTime?

  totalAmount Decimal? @db.Decimal(10, 2)
  notes       String?  @db.Text

  // Shipment Tracking
  trackingNumber String?
  trackingLink   String?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, status])
}

model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String

  productId      String? // Link to internal product
  supplierItemId String? // Link to supplier item catalog
  variationWooId Int?    // WooCommerce variation ID (null = parent/simple product)

  // Snapshot of data at time of order
  name String
  sku  String?

  quantity  Int
  unitCost  Decimal @db.Decimal(10, 2)
  totalCost Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       WooProduct?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplierItem  SupplierItem? @relation(fields: [supplierItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model InventorySettings {
  id        String @id @default(uuid())
  accountId String @unique

  lowStockThresholdDays Int      @default(14)
  alertEmails           String[] // Array of emails to notify
  isEnabled             Boolean  @default(false)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
