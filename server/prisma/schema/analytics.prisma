
// --------------------------------------
// Real-time Analytics (Live View & Carts)
// --------------------------------------

model AnalyticsSession {
  id        String @id @default(uuid())
  accountId String

  visitorId String // UUID from first-party cookie (_os_vid)

  // Demographics
  ipAddress  String?
  userAgent  String?
  country    String?
  city       String?
  deviceType String? // mobile, desktop, tablet
  browser    String?
  os         String?

  // Marketing & Discovery (Attribution)
  referrer    String? // e.g. "google.com" or "facebook.com"
  utmSource   String? // e.g. "newsletter", "google"
  utmMedium   String? // e.g. "email", "cpc"
  utmCampaign String? // e.g. "summer_sale"

  // Live State
  currentPath  String?
  lastActiveAt DateTime @default(now())

  // Cart State (Live Carts)
  cartValue Decimal @default(0) @db.Decimal(10, 2)
  cartItems Json?   @default("[]")
  currency  String  @default("USD")

  // Associated User
  wooCustomerId Int?
  email         String?

  // Attribution Tracking
  firstTouchSource String?
  firstTouchAt     DateTime?
  lastTouchSource  String?
  lastTouchAt      DateTime?
  totalVisits      Int @default(1)

  // Browser Fingerprint Bot Score (0-100+, null = not scored)
  fpScore    Int?
  fpScoredAt DateTime?

  // Abandoned Cart Recovery
  abandonedNotificationSentAt DateTime?

  account Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  events  AnalyticsEvent[]
  visits  AnalyticsVisit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, visitorId])
  @@index([accountId, lastActiveAt])
  @@index([accountId, cartValue])
}

model AnalyticsEvent {
  id        String @id @default(uuid())
  sessionId String
  visitId   String? // Links to specific browsing visit

  type      String // "pageview", "add_to_cart", "search", "purchase"
  url       String
  pageTitle String? // Human readable title
  payload   Json? // e.g. { query: "blue shoes" } for search

  createdAt DateTime @default(now())

  session AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  visit   AnalyticsVisit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([sessionId, type])  // Event type filtering within session
  @@index([visitId])
  @@index([createdAt]) // For time-based cleanup queries
  @@index([type, createdAt(sort: Desc)])  // Cross-session event queries (ecommerce log, behaviour analytics)
}

// Individual browsing visit (session gap detection: 30 min inactivity = new visit)
model AnalyticsVisit {
  id        String @id @default(uuid())
  sessionId String

  visitNumber Int      // Sequential number for this visitor (1, 2, 3...)
  startedAt   DateTime
  endedAt     DateTime?

  // Attribution snapshot for this specific visit
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Device/location snapshot (can change between visits)
  deviceType String?
  browser    String?
  os         String?
  country    String?
  city       String?

  // Aggregate stats for quick display
  pageviews Int @default(0)
  actions   Int @default(0)

  session AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  events  AnalyticsEvent[]

  createdAt DateTime @default(now())

  @@index([sessionId, startedAt])
}

model MessageTrackingEvent {
  id            String   @id @default(uuid())
  emailLogId    String
  eventType     String   // "OPEN", "CLICK"
  linkUrl       String?  // For click events: the URL clicked
  ipCountry     String?  // Privacy-respecting: country only
  userAgent     String?
  
  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([emailLogId])
}

// --------------------------------------
// Analytics & Reporting
// --------------------------------------

model ReportTemplate {
  id        String   @id @default(uuid())
  accountId String
  name      String
  config    Json // Stores metrics, dimension, etc.
  type      String   @default("CUSTOM") // "CUSTOM" or "SYSTEM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  schedules ReportSchedule[]

  @@index([accountId])
}

model ReportSchedule {
  id               String @id @default(uuid())
  reportTemplateId String?
  accountId        String

  // Report type: CUSTOM (uses template) or DIGEST (uses DigestReportService)
  reportType String @default("CUSTOM") // "CUSTOM", "DIGEST"

  frequency  String // "DAILY", "WEEKLY", "MONTHLY"
  dayOfWeek  Int? // 1 (Mon) - 7 (Sun) for WEEKLY
  dayOfMonth Int? // 1-28 for MONTHLY

  time String @default("09:00") // Time to send

  emailRecipients String[] // Array of emails
  isActive        Boolean  @default(true)

  lastRunAt DateTime?
  nextRunAt DateTime?

  template ReportTemplate? @relation(fields: [reportTemplateId], references: [id], onDelete: Cascade)
  account  Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

// --------------------------------------
// Google Search Console
// --------------------------------------

/// Stores Google Search Console connections for organic search analytics.
/// Each account can connect one or more Search Console properties.
model SearchConsoleAccount {
  id           String  @id @default(uuid())
  accountId    String
  siteUrl      String    // e.g. "sc-domain:example.com" or "https://example.com/"
  accessToken  String
  refreshToken String

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, siteUrl])
  @@index([accountId])
}

/// Keywords being actively tracked for rank position over time.
model TrackedKeyword {
  id        String @id @default(uuid())
  accountId String
  keyword   String
  /// Optional: specific page URL to track for this keyword
  targetUrl String?
  /// Current latest position (denormalized for fast reads)
  currentPosition Float?  @default(0)
  /// Current latest CTR (denormalized)
  currentCtr      Float?  @default(0)
  /// Current latest impressions (denormalized)
  currentImpressions Int? @default(0)
  /// Current latest clicks (denormalized)
  currentClicks     Int?  @default(0)
  /// Whether tracking is active
  isActive  Boolean @default(true)

  /// Keyword group for organizing related keywords
  groupId   String?
  group     KeywordGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  /// Estimated monthly revenue attributed to this keyword
  estimatedRevenue      Float?  @default(0)
  /// Estimated monthly search volume from Google Keyword Planner
  estimatedSearchVolume Int?
  /// Pages competing for this keyword (cannibalization detection)
  cannibalizationPages  Json?
  /// Lightweight tags for categorization
  tags                  String[] @default([])

  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  history   KeywordRankHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, keyword])
  @@index([accountId, isActive])
  @@index([groupId])
}

/// Daily rank snapshots for tracked keywords.
model KeywordRankHistory {
  id        String @id @default(uuid())
  keywordId String
  /// Average position on this date
  position  Float
  /// Previous day's position (for delta / alert calculation)
  previousPosition Float?
  clicks    Int    @default(0)
  impressions Int  @default(0)
  ctr       Float  @default(0)
  /// The date this snapshot represents (YYYY-MM-DD)
  date      DateTime @db.Date

  keyword   TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([keywordId, date])
  @@index([keywordId, date(sort: Desc)])
}

/// Keyword groups for organizing tracked keywords.
model KeywordGroup {
  id        String @id @default(uuid())
  accountId String
  name      String
  color     String @default("#6366f1")

  account  Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  keywords TrackedKeyword[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, name])
  @@index([accountId])
}

/// Competitor domains for SERP overlap analysis and position tracking.
model CompetitorDomain {
  id        String  @id @default(uuid())
  accountId String
  domain    String
  notes     String?
  isActive  Boolean @default(true)

  account  Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  keywords CompetitorKeyword[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([accountId, domain])
  @@index([accountId])
}

/// A keyword being tracked for a specific competitor domain.
/// Links competitor domains to the user's tracked keywords to
/// compare positions side-by-side.
model CompetitorKeyword {
  id              String    @id @default(uuid())
  competitorId    String
  keyword         String
  /// Latest known position for this competitor on this keyword
  currentPosition Float?
  /// URL ranking for this keyword (if detected)
  rankingUrl      String?
  lastCheckedAt   DateTime?

  competitor CompetitorDomain       @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  history    CompetitorRankHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([competitorId, keyword])
  @@index([competitorId])
  @@index([keyword])
}

/// Daily position snapshots for competitor keywords.
/// Mirrors KeywordRankHistory but for competitor domains.
model CompetitorRankHistory {
  id                  String   @id @default(uuid())
  competitorKeywordId String
  /// null = not found in top 100
  position            Float?
  previousPosition    Float?
  rankingUrl          String?
  date                DateTime @db.Date

  competitorKeyword CompetitorKeyword @relation(fields: [competitorKeywordId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([competitorKeywordId, date])
  @@index([competitorKeywordId, date(sort: Desc)])
}

// ------------------------------------
// Crawler Detection & Blocking
// ------------------------------------

/// Daily-aggregated log of detected crawler visits for monitoring.
/// One row per crawler per day per account — prevents unbounded growth.
model CrawlerLog {
  id        String   @id @default(uuid())
  accountId String

  crawlerName String              // Normalized: "googlebot", "gptbot", etc.
  category    String  @default("unknown") // "search_engine", "ai_crawler", "seo_tool", "social_preview", "monitor", "security_scanner", "http_client", "unknown"
  sampleAgent String? @db.Text    // One sample UA string for display
  hitCount        Int     @default(1) // Aggregated daily hit count (unblocked)
  blockedHitCount Int     @default(0) // Hits received while crawler was blocked
  date        DateTime @db.Date   // Calendar date (truncated to midnight)
  country     String?             // GeoIP country of crawler IP
  city        String?             // GeoIP city (optional)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, crawlerName, date])
  @@index([accountId, date])
  @@index([accountId, crawlerName])
}

/// Per-account rules for blocking/allowing specific crawlers.
model CrawlerRule {
  id        String   @id @default(uuid())
  accountId String

  crawlerName String              // e.g. "gptbot", "semrushbot"
  pattern     String              // UA pattern to match (lowercase)
  action      String  @default("ALLOW") // "BLOCK" or "ALLOW"
  reason      String?             // Admin note for why it was blocked
  blockedBy   String?             // User ID who created the rule (plain FK, no Prisma relation)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, crawlerName])
  @@index([accountId, action])
}

// ------------------------------------
// Real User Monitoring — Web Vitals
// ------------------------------------

/// Individual Core Web Vital measurement from a real page load.
/// One row per metric per page load. p75/p90 are queried ad-hoc.
/// Retained for 90 days — cleaned up by nightly MaintenanceScheduler job.
model WebVitalSample {
  id        String   @id @default(uuid())
  accountId String

  metric    String              // "LCP" | "CLS" | "INP" | "FCP" | "TTFB"
  value     Float               // ms for timing metrics; unitless for CLS
  rating    String              // "good" | "needs-improvement" | "poor"
  url       String   @db.VarChar(500) // Page path (no query string)
  pageType  String   @default("other") // "product" | "category" | "cart" | "checkout" | "home" | "other"
  device    String   @default("desktop") // "mobile" | "tablet" | "desktop"
  effectiveType String?         // "4g" | "3g" | "2g" | "slow-2g" (navigator.connection)

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, metric, createdAt])
  @@index([accountId, pageType, metric])
  @@index([createdAt])  // For 90-day cleanup job
}
