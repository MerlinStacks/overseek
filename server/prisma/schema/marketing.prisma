
model AdAccount {
  id           String  @id @default(uuid())
  accountId    String
  platform     String // "META", "GOOGLE"
  externalId   String? // Ad Account ID
  name         String?
  accessToken  String // Encrypt in real app!
  refreshToken String?
  currency     String?

  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots     AdPerformanceSnapshot[]
  audienceSyncs AudienceSync[]

  @@index([accountId])
}

// --------------------------------------
// Ad Performance Snapshots (AI Marketing Co-Pilot)
// --------------------------------------

/// Daily snapshot of ad performance metrics for historical analysis.
/// Used by the AI Marketing Co-Pilot for multi-period comparison (7d/30d/90d),
/// trend detection, and seasonality analysis.
model AdPerformanceSnapshot {
  id          String   @id @default(uuid())
  accountId   String
  adAccountId String
  platform    String   // "GOOGLE" | "META"
  date        DateTime @db.Date

  // Core metrics
  spend           Float
  revenue         Float
  clicks          Int
  impressions     Int
  conversions     Float

  // Derived metrics (calculated for query efficiency)
  roas            Float
  ctr             Float
  cpc             Float
  cpa             Float

  // Optional breakdowns (JSON for flexibility)
  campaignBreakdown Json?  // { campaignId: { spend, revenue, clicks, ... } }
  deviceBreakdown   Json?  // { mobile: { ... }, desktop: { ... } }
  geoBreakdown      Json?  // { AU: { ... }, US: { ... } }

  adAccount   AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([adAccountId, date])
  @@index([accountId, date])
  @@index([adAccountId, date])
}

// --------------------------------------
// Recommendation Tracking (AI Marketing Co-Pilot Phase 5)
// --------------------------------------

/// Tracks AI-generated recommendations and their outcomes for learning.
model RecommendationLog {
  id          String   @id @default(uuid())
  accountId   String
  
  // Recommendation details
  recommendationId  String    // Unique ID from knowledge base (e.g., "google_pmax_learning")
  text              String    @db.Text
  category          String    // bid_strategy, audience, creative, budget, structure, optimization
  priority          Int       // 1=urgent, 2=important, 3=info
  platform          String?   // google, meta, both
  campaignId        String?   // Associated campaign if applicable
  campaignName      String?
  
  // Confidence at time of generation
  confidenceScore   Int       // 0-100
  confidenceLevel   String    // high, medium, low
  
  // User interaction
  status            String    @default("pending") // pending, implemented, dismissed, expired
  implementedAt     DateTime?
  dismissedAt       DateTime?
  dismissReason     String?   // "not_relevant", "already_done", "disagree", "will_do_later"
  userFeedback      String?   @db.Text  // User's explanation/context for future recommendations
  
  // Outcome tracking (populated after implementation)
  outcomeRecordedAt DateTime?
  roasBefore        Float?
  roasAfter         Float?
  roasChange        Float?    // Percentage change
  wasSuccessful     Boolean?  // Did ROAS improve?
  outcomeNotes      String?   @db.Text
  
  // Metadata
  dataPoints        Json?     // Supporting data at time of generation
  tags              Json?     // Array of tags
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([accountId, createdAt])
  @@index([accountId, status])
  @@index([recommendationId])
}

// --------------------------------------
// Marketing Knowledge Base (AI Marketing Co-Pilot Phase 4)
// --------------------------------------

/// Account-specific marketing learnings and optimization rules.
/// These are user-created or AI-suggested rules that extend the static knowledge base.
model MarketingLearning {
  id          String   @id @default(uuid())
  accountId   String
  
  platform    String   // google, meta, both
  category    String   // bid_strategy, audience, creative, budget, structure, optimization
  condition   String   @db.Text  // Human-readable condition description
  recommendation String @db.Text
  explanation String?  @db.Text
  
  source      String   @default("user") // user, ai_derived
  isActive    Boolean  @default(true)
  isPending   Boolean  @default(false) // AI-derived rules awaiting user approval
  
  appliedCount Int     @default(0)  // Times this rule has triggered
  successCount Int     @default(0)  // Times the outcome was positive
  
  // Source tracking for AI-derived rules
  derivedFromRecommendationIds Json?  // Array of recommendation IDs that led to this learning
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([accountId, isActive])
  @@index([accountId, isPending])
}

// --------------------------------------
// Ad Alerts (AI Marketing Co-Pilot Phase 6)
// --------------------------------------

/// Stores proactive ad performance alerts for audit and deduplication.
model AdAlert {
  id          String   @id @default(uuid())
  accountId   String
  
  severity    String   // critical, warning, info
  type        String   // roas_crash, zero_conversions, ctr_crash, budget_depleting, anomaly
  title       String
  message     String   @db.Text
  
  platform    String?  // google, meta
  adAccountId String?
  campaignId  String?
  campaignName String?
  
  data        Json?    // Supporting data (metrics, thresholds, etc.)
  
  // Status
  isAcknowledged Boolean @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?  // User ID
  
  // Notification tracking
  notificationSent Boolean @default(false)
  
  createdAt   DateTime @default(now())
  
  @@index([accountId, createdAt])
  @@index([accountId, isAcknowledged])
  @@index([accountId, type, createdAt])
}

// --------------------------------------
// Scheduled Ad Actions
// --------------------------------------

/// Stores scheduled ad optimization actions (budget changes, pauses, etc.)
model ScheduledAdAction {
  id            String   @id @default(uuid())
  accountId     String
  
  // Action details
  actionType    String   // "budget_increase", "budget_decrease", "pause", "enable"
  platform      String   // "google", "meta"
  adAccountId   String?
  campaignId    String?
  campaignName  String?
  
  // Parameters
  parameters    Json     // { currentBudget, newBudget, changeAmount, etc. }
  
  // Scheduling
  scheduledFor  DateTime
  executedAt    DateTime?
  status        String   @default("pending")  // "pending", "executed", "failed", "cancelled"
  
  // Auto-execution settings (Phase 3: Campaign Automation)
  autoExecute   Boolean  @default(false)  // If true, execute without user approval
  executeAfter  DateTime?                 // Don't execute before this time (cooldown)
  maxDailySpend Float?                    // Spend cap for the day (protection)
  sourceType    String   @default("manual") // "manual", "rebalancer", "recommendation"
  
  // Result tracking
  error         String?  @db.Text
  resultData    Json?    // Response from API after execution
  
  // Reference
  recommendationId String?  // Links back to original recommendation
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([accountId, status])
  @@index([scheduledFor, status])
  @@index([autoExecute, status, scheduledFor])
}

/// Audit log for executed ad actions (budget changes, status changes, etc.)
model AdActionLog {
  id           String   @id @default(uuid())
  accountId    String
  adAccountId  String
  campaignId   String
  actionType   String   // budget_increase, budget_decrease, pause, enable, keyword_add
  platform     String   // google, meta
  parameters   Json     // Action parameters (amount, status, etc.)
  status       String   // completed, failed
  executedAt   DateTime
  error        String?  @db.Text
  
  createdAt    DateTime @default(now())
  
  @@index([accountId, executedAt])
  @@index([campaignId])
}

/// A/B test experiment for ad creatives (Phase 4: Creative A/B Engine)
model CreativeExperiment {
  id            String   @id @default(uuid())
  accountId     String
  
  name          String
  status        String   @default("RUNNING")  // RUNNING, PAUSED, COMPLETED
  platform      String   // "google", "meta"
  adAccountId   String
  campaignId    String?
  adGroupId     String?
  
  // Winning criteria
  primaryMetric String   @default("ctr")  // ctr, conversions, roas
  minSampleSize Int      @default(100)    // Min impressions per variant
  confidenceLevel Float  @default(0.95)   // 95% confidence required
  
  // Timing
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  variants      CreativeVariant[]
  
  @@index([accountId, status])
  @@index([adAccountId, status])
}

/// Individual variant in an A/B test (Phase 4: Creative A/B Engine)
model CreativeVariant {
  id            String   @id @default(uuid())
  experimentId  String
  
  variantLabel  String   // "A", "B", "C", etc.
  isControl     Boolean  @default(false)
  status        String   @default("ACTIVE")  // ACTIVE, PAUSED, WINNER, LOSER
  
  // Creative content
  headlines     Json?    // Array of headlines
  descriptions  Json?    // Array of descriptions
  primaryTexts  Json?    // Meta primary texts
  externalAdId  String?  // ID in the ad platform
  
  // Performance metrics (refreshed periodically)
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  spend         Float    @default(0)
  revenue       Float    @default(0)
  
  // Calculated metrics
  ctr           Float?   // Click-through rate
  conversionRate Float?  // Conversion rate
  roas          Float?   // Return on ad spend
  
  // Statistical analysis
  pValue        Float?   // p-value vs control
  isSignificant Boolean  @default(false)
  
  metricsUpdatedAt DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  experiment    CreativeExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  
  @@index([experimentId, status])
}

/// Generated executive reports (Phase 5: Executive Report Generation)
model ExecutiveReport {
  id            String   @id @default(uuid())
  accountId     String
  
  periodStart   DateTime
  periodEnd     DateTime
  
  // Report file
  fileName      String
  filePath      String
  fileSize      Int
  
  // Metadata
  generatedBy   String?  // user ID who requested
  metrics       Json?    // Snapshot of metrics at generation time
  
  createdAt     DateTime @default(now())
  
  @@index([accountId, createdAt])
}

// --------------------------------------
// Marketing & Automation
// --------------------------------------

model EmailTemplate {
  id        String  @id @default(uuid())
  accountId String
  name      String
  subject   String?

  // HTML Content or JSON for a block builder
  content    String @db.Text
  designJson Json? // For drag-and-drop builder state

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, name])
}

model MarketingCampaign {
  id        String @id @default(uuid())
  accountId String
  name      String

  subject    String
  content    String @db.Text // Rendered HTML
  designJson Json? // For drag-and-drop builder state

  status String @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, FAILED

  scheduledAt DateTime?
  sentAt      DateTime?

  segmentId String?
  segment   CustomerSegment? @relation(fields: [segmentId], references: [id])

  // Stats
  recipientsCount Int @default(0)
  sentCount       Int @default(0)
  openedCount     Int @default(0)
  clickedCount    Int @default(0)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, status])           // Campaign list by status
  @@index([accountId, scheduledAt])      // Scheduled sends lookup
}

model MarketingAutomation {
  id        String  @id @default(uuid())
  accountId String
  name      String
  isActive  Boolean @default(false)

  // Trigger Configuration
  triggerType   String // "ORDER_CREATED", "ORDER_COMPLETED", "REVIEW_LEFT", "ABANDONED_CART"
  triggerConfig Json?  @default("{}") // Filters like { "minOrderValue": 100 }

  // Flow Definition (React Flow Graph)
  flowDefinition Json? @default("{}")

  status String @default("PAUSED") // ACTIVE, PAUSED, DRAFT

  // Ordered list of steps
  steps AutomationStep[]

  enrollments AutomationEnrollment[]
  runEvents   AutomationRunEvent[]
  goalEvents  AutomationGoalEvent[]
  generatedCoupons GeneratedCoupon[]

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationStep {
  id           String @id @default(uuid())
  automationId String

  stepOrder Int // 1, 2, 3...

  type   String // "DELAY", "SEND_EMAIL", "CONDITION"
  config Json // e.g. { "durationSeconds": 3600 } or { "templateId": "...", "subject": "..." }

  automation MarketingAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model AutomationEnrollment {
  id           String @id @default(uuid())
  automationId String
  accountId    String

  // Target entity
  wooCustomerId Int?
  email         String

  // Context data (e.g. invalidating if a new order comes in, or storing the Order ID that triggered this)
  contextData Json?

  status              String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  statusReason        String?
  currentNodeId       String? // React Flow Node ID tracking progress
  lastProcessedNodeId String?

  triggerEntityType String? // ORDER, CART, CUSTOMER, REVIEW
  triggerEntityId   String?
  dedupeKey         String?

  nextRunAt DateTime? // When to process the next step
  enteredAt  DateTime @default(now())
  completedAt DateTime?
  cancelledAt DateTime?
  conversionAt DateTime?
  convertedOrderId String?
  convertedRevenue Decimal? @db.Decimal(10, 2)
  lastEmailLogId String?

  automation MarketingAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  account    Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  runEvents  AutomationRunEvent[]
  goalEvents AutomationGoalEvent[]
  generatedCoupons GeneratedCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([automationId, status, nextRunAt])
  @@index([accountId, status, nextRunAt])
  @@index([accountId, email, status])
  @@index([accountId, triggerEntityType, triggerEntityId])
  @@index([accountId, dedupeKey])
}

model AutomationRunEvent {
  id           String @id @default(uuid())
  accountId    String
  automationId String
  enrollmentId String

  nodeId    String?
  eventType String // ENROLLED, NODE_EXECUTED, WAITING, COMPLETED, CANCELLED, FAILED, SKIPPED
  outcome   String?
  metadata  Json?

  account    Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  automation MarketingAutomation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  enrollment AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([accountId, automationId, createdAt])
  @@index([accountId, enrollmentId, createdAt])
  @@index([automationId, nodeId, createdAt])
}

model AutomationGoalEvent {
  id           String @id @default(uuid())
  accountId    String
  automationId String
  enrollmentId String

  goalType               String // PURCHASE, RECOVERY, REVIEW, CUSTOM
  orderId                String?
  revenue                Decimal? @db.Decimal(10, 2)
  attributionWindowHours Int      @default(168)
  metadata               Json?

  account    Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  automation MarketingAutomation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  enrollment AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([accountId, automationId, createdAt])
  @@index([accountId, enrollmentId, createdAt])
  @@index([accountId, orderId])
}

model GeneratedCoupon {
  id           String @id @default(uuid())
  accountId    String
  automationId String
  enrollmentId String

  wooCouponId   Int?
  code          String
  amount        Decimal  @db.Decimal(10, 2)
  discountType  String
  description   String?
  expiresAt     DateTime?
  usedAt        DateTime?
  orderId       String?
  metadata      Json?

  account    Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  automation MarketingAutomation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  enrollment AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, code])
  @@index([accountId, automationId, createdAt])
  @@index([accountId, enrollmentId, createdAt])
}

// --------------------------------------
// Campaign ROI Tracking
// --------------------------------------

/// Tracks campaign events for ROI attribution.
/// Links sends, opens, clicks, and purchases to campaigns.
model CampaignEvent {
  id        String   @id @default(uuid())
  accountId String

  /// Campaign identifier (automation ID, broadcast ID, etc.)
  campaignId   String?
  campaignType String?  // 'automation', 'broadcast', 'one-off'

  /// Event type: 'send', 'open', 'click', 'unsubscribe', 'purchase'
  eventType String

  /// Recipient info
  recipientEmail String?
  recipientPhone String?

  /// For click events: the link clicked
  linkUrl String?

  /// For purchase attribution
  orderId  String?
  revenue  Float?

  /// UTM parameters for source tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  /// Additional context
  metadata Json?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([accountId, campaignId])
  @@index([accountId, eventType, createdAt])
  @@index([recipientEmail, createdAt])
}

/// Tracks email unsubscribes per account.
model EmailUnsubscribe {
  id        String   @id @default(uuid())
  accountId String
  email     String
  scope     String   @default("MARKETING") // MARKETING, ALL
  reason    String?
  
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([accountId, email])
  @@index([accountId])
}

model CustomerSegment {
  id          String  @id @default(uuid())
  accountId   String
  name        String
  description String?
  criteria    Json // e.g. { type: "AND", rules: [{ field: "totalSpent", operator: "gt", value: 100 }] }

  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaigns     MarketingCampaign[]
  audienceSyncs AudienceSync[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, name])
}

/// Tracks synchronization of customer segments to ad platform audiences.
/// Used for Meta Custom Audiences and Google Customer Match.
model AudienceSync {
  id           String   @id @default(uuid())
  accountId    String
  segmentId    String
  adAccountId  String   // Links to AdAccount for platform credentials
  
  platform     String   // 'GOOGLE' | 'META'
  externalId   String?  // Platform's audience ID after creation
  audienceName String   // Name on the platform
  
  status       String   @default("PENDING") // 'PENDING' | 'SYNCING' | 'SYNCED' | 'FAILED'
  lastSyncAt   DateTime?
  lastError    String?  @db.Text
  memberCount  Int?     // Number of matched users
  
  // Lookalike settings (if derived)
  isLookalike       Boolean @default(false)
  sourceAudienceId  String? // Parent AudienceSync ID if lookalike
  lookalikePercent  Float?  // 1, 3, or 5 percent
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  segment   CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  adAccount AdAccount       @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  
  @@unique([accountId, segmentId, platform, adAccountId])
  @@index([accountId, platform])
  @@index([adAccountId])
}


// --------------------------------------
// AI Ad Optimization Context
// --------------------------------------

model AdSuggestionContext {
  id        String   @id @default(uuid())
  accountId String   @unique
  context   String   @db.Text  // User-provided business context for AI suggestions
  
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
