{
    "name": "overseek-server",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "nodemon -r ts-node/register src/index.ts | pino-pretty --translateTime \"SYS:standard\" --ignore time,pid,hostname",
        "build": "npm --prefix .. run build -w @overseek/core && npx tsc",
        "build:typecheck": "npm --prefix .. run build -w @overseek/core && npx tsc --noEmit",
        "start": "node --disable-warning=DEP0040 dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "build:plugin": "node scripts/build_plugin.js",
        "lint": "eslint .",
        "mock:account": "npx ts-node src/scripts/setupMockAccount.ts",
        "mock:seed": "npx ts-node src/scripts/seedMockData.ts",
        "mock:reset": "npx ts-node src/scripts/resetMockData.ts"
    },
    "dependencies": {
        "@bull-board/api": "^8.1.2",
        "@bull-board/fastify": "^8.1.2",
        "@elastic/elasticsearch": "^9.4.2",
        "@fastify/compress": "^9.1.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/multipart": "^10.1.0",
        "@fastify/rate-limit": "^11.1.0",
        "@fastify/static": "^10.1.0",
        "@fontsource/noto-sans": "^5.2.10",
        "@overseek/core": "1.0.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@socket.io/redis-adapter": "^8.3.0",
        "@types/bcryptjs": "^2.4.6",
        "@woocommerce/woocommerce-rest-api": "^1.0.2",
        "argon2": "^0.44.0",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.80.5",
        "dotenv": "^17.4.2",
        "fastify": "^5.10.0",
        "google-ads-api": "^24.1.0",
        "imapflow": "^1.4.7",
        "ioredis": "^5.11.1",
        "jsonwebtoken": "^9.0.3",
        "mailparser": "^3.9.14",
        "maxmind": "^5.0.6",
        "nodemailer": "^9.0.3",
        "otplib": "^13.4.1",
        "pdfkit": "^0.19.1",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.0.0",
        "prisma": "^7.8.0",
        "qrcode": "^1.5.4",
        "socket.io": "^4.8.3",
        "ua-parser-js": "^2.0.10",
        "web-push": "^3.6.7",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mailparser": "^3.4.6",
        "@types/node": "^22.20.1",
        "@types/nodemailer": "^8.0.1",
        "@types/pdfkit": "^0.17.6",
        "@types/pg": "^8.20.0",
        "@types/qrcode": "^1.5.6",
        "@types/ua-parser-js": "^0.7.39",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^4.1.10",
        "esbuild": "^0.28.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
